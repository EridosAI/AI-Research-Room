# --- secrets: NEVER commit. The real protection is that keys live outside the
# repo entirely (~/.config/research-room/secrets.json, chmod 600); these are
# belt-and-suspenders in case a secrets file ever lands in-tree. ---
secrets.json
**/secrets.json
.config/

# --- local engine state ---
vault/.current
# Rooms are folders under the vault (vault/<room_id>/{main,margin}.jsonl + room.json).
# Keep the vault dir (.gitkeep), not its contents — point RESEARCH_ROOM_VAULT at your
# own (Obsidian) vault to track transcripts there.
vault/*/
vault/*.jsonl          # legacy flat transcripts (pre-rooms), if any linger

# --- python ---
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/
dist/

# --- python venv ---
.venv/
venv/

# --- personal launcher icon: drop your own room.ico for the Desktop shortcut ---
room.ico

# --- pre-build scaffolding kept locally for reference, not published ---
_archive/
